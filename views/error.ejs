<!-- views/error.ejs -->
<!-- Жанабекұлы Ислам — Қате беті (404 / 500) -->
<!DOCTYPE html>
<html lang="kk">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Ас үй Рецептері</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .error-page {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #f7f3ee;
      font-family: 'Segoe UI', sans-serif;
      padding: 20px;
    }
    .error-card {
      background: white;
      border-radius: 16px;
      padding: 50px 40px;
      text-align: center;
      box-shadow: 0 8px 30px rgba(0,0,0,0.1);
      max-width: 600px;
      width: 100%;
    }
    .error-code {
      font-size: 5rem;
      font-weight: 900;
      color: #F6AD55;
      line-height: 1;
      margin-bottom: 10px;
    }
    .error-title {
      font-size: 1.5rem;
      color: #333;
      margin-bottom: 12px;
    }
    .error-message {
      color: #777;
      font-size: 1rem;
      margin-bottom: 28px;
      line-height: 1.6;
    }
    .error-stack {
      text-align: left;
      background: #f5f5f5;
      border: 1px solid #e0e0e0;
      border-radius: 8px;
      padding: 18px;
      font-size: 0.78rem;
      font-family: monospace;
      overflow-x: auto;
      color: #555;
      margin-bottom: 24px;
      white-space: pre-wrap;
      word-break: break-word;
    }
    .btn-home {
      display: inline-block;
      padding: 14px 36px;
      background: linear-gradient(90deg, #F6AD55, #ED8936);
      color: white;
      border-radius: 10px;
      text-decoration: none;
      font-weight: 700;
      font-size: 1rem;
      transition: opacity 0.2s;
      box-shadow: 0 4px 14px rgba(246,173,85,0.35);
    }
    .btn-home:hover { opacity: 0.88; }
  </style>
</head>
<body>
  <div class="error-page">
    <div class="error-card">

      <!-- Қате коды -->
      <div class="error-code">
        <% if (title.includes('404')) { %>
          404
        <% } else { %>
          ⚠️
        <% } %>
      </div>

      <h2 class="error-title"><%= title %></h2>
      <p class="error-message"><%= message %></p>

      <!-- Stack trace тек development режімінде -->
      <% if (stack) { %>
        <div class="error-stack"><%= stack %></div>
      <% } %>

      <a href="/" class="btn-home">← Басты бетке оралу</a>

    </div>
  </div>
</body>
</html>
