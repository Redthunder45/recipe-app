{
  "name": "recipe-app",
  "version": "1.0.0",
  "description": "Ас үй рецептері сайты — Node.js + Express + MongoDB + Auth + PM2",
  "main": "server.js",
  "scripts": {
    "start":   "node server.js",
    "dev":     "nodemon server.js",
    "pm2:dev": "pm2 start ecosystem.config.js",
    "pm2:prod":"pm2 start ecosystem.config.js --env production",
    "pm2:stop":"pm2 stop recipe-app",
    "pm2:logs":"pm2 logs recipe-app"
  },
  "author": "Жанабекұлы Ислам",
  "license": "ISC",
  "dependencies": {
    "bcryptjs":        "^2.4.3",
    "connect-flash":   "^0.1.1",
    "ejs":             "^3.1.9",
    "express":         "^4.18.2",
    "express-session": "^1.17.3",
    "express-validator":"^7.0.1",
    "method-override": "^3.0.0",
    "mongoose":        "^8.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "pm2":     "^5.3.0"
  }
}
